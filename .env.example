# ===== Bắt buộc khi frontend và backend khác domain =====
# Ví dụ: https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ===== AI =====
# Có OPENAI_API_KEY thì trả lời và phân tích file tốt hơn.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== Database =====
# Local mặc định dùng SQLite nếu bỏ trống DATABASE_URL.
# Production nên dùng PostgreSQL/Supabase để lịch sử không mất khi service restart.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# ===== Bảo vệ API (tùy chọn cho demo nội bộ) =====
# Không đặt secret này vào frontend công khai. Để trống nếu đang làm MVP public.
FINIIP_API_KEY=
FINIIP_ADMIN_KEY=

# ===== RAG =====
RAG_STORAGE_MODE=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RAG_BUCKET=rag-knowledge
RAG_MAX_UPLOAD_BYTES=20971520
RAG_MAX_BATCH_FILES=12
RAG_PRO_CHUNK_SIZE=1600
RAG_PRO_OVERLAP=220
